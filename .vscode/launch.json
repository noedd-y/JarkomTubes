    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "ClientGUI",
            "request": "launch",
            "mainClass": "ClientGUI",
        },
        {
            "type": "java",
            "name": "Run Server",
            "request": "launch",
            "mainClass": "Server",
            "vmArgs": "-Djavax.net.ssl.keyStore=serverkeystore.jks -Djavax.net.ssl.keyStorePassword=123456",
            "preLaunchTask": "java (build): Build Workspace"
        },
        {
            "type": "java",
            "name": "Run Client",
            "request": "launch",
            "mainClass": "Client",
            "vmArgs": "-Djavax.net.ssl.trustStore=serverkeystore.jks -Djavax.net.ssl.trustStorePassword=123456",
            "preLaunchTask": "java (build): Build Workspace"
        }
    ]
}